.obstacle-map-page {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #f3f4f6;
}

.main-map {
  width: 100%;
  height: 100%;
}

.top-panel {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding-left: 12px;
  padding-right: 12px;
  z-index: 20;
}

.search-entry {
  height: 40px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 12px;
  box-shadow: 0 4px 12px rgba(15, 23, 42, 0.12);
}

.search-icon {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.search-text {
  font-size: 14px;
  color: #4b5563;
}

.control-row {
  margin-top: 10px;
  display: flex;
  gap: 8px;
}

.control-btn {
  min-width: 84px;
  height: 34px;
  padding: 0 12px;
  border-radius: 17px;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 4px 10px rgba(15, 23, 42, 0.12);
  font-size: 13px;
  color: #1f2937;
  display: flex;
  align-items: center;
  justify-content: center;
}

.control-btn.danger {
  color: #b91c1c;
}

.control-btn.disabled {
  color: #9ca3af;
}

.hint-row {
  margin-top: 8px;
  font-size: 12px;
  color: #b45309;
  background: rgba(255, 251, 235, 0.95);
  border-radius: 12px;
  padding: 7px 10px;
}

.route-summary {
  margin-top: 8px;
  font-size: 12px;
  color: #1d4ed8;
  background: rgba(239, 246, 255, 0.96);
  border-radius: 12px;
  padding: 7px 10px;
}

.loading-badge {
  position: absolute;
  left: 12px;
  top: 150px;
  z-index: 22;
  font-size: 12px;
  color: #1f2937;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12px;
  padding: 8px 10px;
  box-shadow: 0 4px 10px rgba(15, 23, 42, 0.12);
}

.community-status-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 21;
  background: rgba(255, 255, 255, 0.98);
  border-top-left-radius: 18px;
  border-top-right-radius: 18px;
  box-shadow: 0 -8px 24px rgba(15, 23, 42, 0.16);
  box-sizing: border-box;
  overflow: hidden;
  display: none;
  transition: height 180ms ease;
}

.community-status-sheet.show {
  display: flex;
  flex-direction: column;
}

.community-status-sheet.dragging {
  transition: none;
}

.sheet-drag-zone {
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.sheet-drag-handle {
  width: 40px;
  height: 4px;
  border-radius: 999px;
  background: #cbd5e1;
}

.sheet-header {
  min-height: 40px;
  padding: 0 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #eef2f7;
  flex-shrink: 0;
}

.sheet-title {
  font-size: 14px;
  color: #111827;
  font-weight: 600;
}

.sheet-count {
  min-width: 22px;
  height: 22px;
  padding: 0 8px;
  border-radius: 11px;
  font-size: 12px;
  color: #1d4ed8;
  background: #eaf2ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-loading,
.sheet-empty {
  padding: 14px;
  text-align: center;
  font-size: 13px;
  color: #6b7280;
}

.sheet-list {
  max-height: calc(42vh - 44px);
}

.community-status-body {
  padding: 12px 14px 16px;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.community-status-meta {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 12px;
  color: #6b7280;
  line-height: 1.4;
}

.community-actions {
  margin-top: 14px;
  display: flex;
  gap: 10px;
  flex-shrink: 0;
}

.community-action {
  flex: 1;
  height: 38px;
  border-radius: 19px;
  background: #eef2f7;
  color: #1f2937;
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.community-action.primary {
  background: #002fa7;
  color: #ffffff;
}

.community-post-list {
  margin-top: 12px;
  flex: 1;
  min-height: 0;
  border-top: 1px solid #eef2f7;
}

.community-post-row {
  min-height: 58px;
  padding: 10px 0;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid #f1f5f9;
}

.community-post-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.community-post-title,
.community-post-tag {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.community-post-title {
  font-size: 14px;
  color: #111827;
  font-weight: 600;
}

.community-post-tag {
  font-size: 12px;
  color: #64748b;
}

.community-post-status {
  min-width: 48px;
  height: 24px;
  padding: 0 8px;
  border-radius: 12px;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  color: #475569;
  background: #f1f5f9;
}

.community-post-status.status-pending {
  color: #92400e;
  background: #fef3c7;
}

.community-post-status.status-processing {
  color: #1d4ed8;
  background: #dbeafe;
}

.community-post-status.status-completed {
  color: #047857;
  background: #d1fae5;
}

.community-post-empty,
.community-post-loading {
  padding: 14px 0;
  text-align: center;
  font-size: 12px;
  color: #94a3b8;
}

.sheet-item {
  min-height: 54px;
  padding: 10px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  border-bottom: 1px solid #f1f5f9;
}

.item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.item-title {
  font-size: 14px;
  color: #111827;
  line-height: 1.3;
}

.item-address {
  font-size: 12px;
  color: #6b7280;
  line-height: 1.3;
}

.item-distance {
  font-size: 12px;
  color: #1d4ed8;
  white-space: nowrap;
}

.search-overlay {
  position: absolute;
  inset: 0;
  z-index: 40;
}

.search-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.28);
}

.search-panel {
  position: absolute;
  top: 12px;
  left: 12px;
  right: 12px;
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 28px rgba(15, 23, 42, 0.18);
}

.search-row {
  height: 48px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  gap: 8px;
  border-bottom: 1px solid #eef2f7;
}

.manual-pick-row {
  min-height: 42px;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid #eef2f7;
}

.manual-pick-btn {
  height: 28px;
  padding: 0 12px;
  border-radius: 14px;
  background: #eaf2ff;
  color: #1d4ed8;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.manual-pick-tip {
  flex: 1;
  min-width: 0;
  font-size: 12px;
  color: #b45309;
  line-height: 1.3;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #111827;
}

.search-cancel {
  font-size: 13px;
  color: #1d4ed8;
}

.search-list {
  max-height: 70vh;
}

.search-item {
  padding: 12px;
  border-bottom: 1px solid #f1f5f9;
}

.search-title {
  display: block;
  font-size: 14px;
  color: #111827;
  line-height: 1.4;
}

.search-address {
  display: block;
  margin-top: 4px;
  font-size: 12px;
  color: #6b7280;
  line-height: 1.3;
}

.search-empty,
.search-loading {
  padding: 14px;
  text-align: center;
  font-size: 13px;
  color: #6b7280;
}
