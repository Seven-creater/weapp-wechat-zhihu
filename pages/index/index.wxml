<view class="obstacle-map-page">
  <map
    id="mainMap"
    class="main-map"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
    polyline="{{polyline}}"
    show-location
    bindmarkertap="handleMarkerTap"
    bindregionchange="onRegionChange"
  />

  <view class="top-panel" style="padding-top: {{topInset + 8}}px;">
    <view class="search-entry" bindtap="onSearchTap">
      <image class="search-icon" src="/images/search.png" mode="aspectFit" />
      <text class="search-text">{{destinationLabel || '查询社区障碍信息'}}</text>
    </view>

    <view class="control-row">
      <view class="control-btn" bindtap="onCenterTap">我的位置</view>
    </view>

    <view class="hint-row" wx:if="{{!hasLocationPermission}}">
      定位未授权，仍可查询社区障碍信息
    </view>
  </view>

  <view class="loading-badge" wx:if="{{loadingObstacles}}">
    加载障碍点...
  </view>

  <view
    class="community-status-sheet {{communitySummaryVisible ? 'show' : ''}} {{communitySheetExpanded ? 'expanded' : 'collapsed'}} {{communitySheetDragging ? 'dragging' : ''}}"
    style="height: {{communitySheetHeight}}px; padding-bottom: {{safeBottom}}px;"
  >
    <view
      class="sheet-drag-zone"
      bindtouchstart="onCommunitySheetTouchStart"
      catchtouchmove="onCommunitySheetTouchMove"
      bindtouchend="onCommunitySheetTouchEnd"
      bindtouchcancel="onCommunitySheetTouchEnd"
    >
      <view class="sheet-drag-handle"></view>
    </view>
    <view
      class="sheet-header"
      bindtouchstart="onCommunitySheetTouchStart"
      catchtouchmove="onCommunitySheetTouchMove"
      bindtouchend="onCommunitySheetTouchEnd"
      bindtouchcancel="onCommunitySheetTouchEnd"
    >
      <text class="sheet-title">{{communitySummary.community || selectedCommunity}}</text>
      <text class="sheet-count">{{communitySummary.total || 0}} 条信息</text>
    </view>

    <view class="sheet-loading" wx:if="{{communitySummaryLoading}}">
      正在查询社区障碍信息...
    </view>

    <view class="community-status-body" wx:if="{{communitySummaryVisible && !communitySummaryLoading}}">
      <view class="community-status-meta">
        <text>最近更新：{{communitySummary.updatedAt || '暂无更新'}}</text>
        <text>地图已定位到该社区障碍点分布范围</text>
      </view>
      <view class="community-actions">
        <view class="community-action primary" bindtap="onCommunityDetailTap">帖子详情</view>
        <view class="community-action" bindtap="onGenerateCommunityReportTap">生成社区报告</view>
      </view>
      <scroll-view
        wx:if="{{communitySheetExpanded}}"
        class="community-post-list"
        scroll-y
        lower-threshold="60"
        bindscrolltolower="onCommunityPostListLower"
      >
        <view
          class="community-post-row"
          wx:for="{{communityPostRows}}"
          wx:key="postId"
          data-post-id="{{item.postId}}"
          bindtap="onCommunityPostTap"
        >
          <view class="community-post-main">
            <text class="community-post-title">{{item.title}}</text>
            <text class="community-post-tag">{{item.tag}}</text>
          </view>
          <text class="community-post-status status-{{item.status}}">{{item.statusText}}</text>
        </view>
        <view class="community-post-empty" wx:if="{{!communityPostLoadingMore && communityPostRows.length === 0}}">
          暂无帖子
        </view>
        <view class="community-post-loading" wx:if="{{communityPostLoadingMore}}">
          加载更多...
        </view>
        <view class="community-post-loading" wx:if="{{!communityPostLoadingMore && communityPostRows.length > 0 && !communityPostPagination.hasMore}}">
          已展示全部帖子
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="search-overlay" wx:if="{{searchVisible}}">
    <view class="search-mask" bindtap="onSearchClose" />
    <view class="search-panel">
      <view class="search-row">
        <image class="search-icon" src="/images/search.png" mode="aspectFit" />
        <input
          class="search-input"
          value="{{searchKeyword}}"
          placeholder="输入社区名称"
          bindinput="onSearchInput"
          focus
          confirm-type="search"
        />
        <text class="search-cancel" bindtap="onSearchClose">取消</text>
      </view>

      <scroll-view class="search-list" scroll-y>
        <view
          class="search-item"
          wx:for="{{searchResults}}"
          wx:key="id"
          data-index="{{index}}"
          bindtap="onSearchSelect"
        >
          <text class="search-title">{{item.title}}</text>
          <text class="search-address" wx:if="{{item.address}}">{{item.address}}</text>
        </view>

        <view class="search-empty" wx:if="{{!searchLoading && searchKeyword && searchResults.length === 0}}">
          暂无匹配社区
        </view>

        <view class="search-loading" wx:if="{{searchLoading}}">
          搜索中...
        </view>
      </scroll-view>
    </view>
  </view>
</view>
