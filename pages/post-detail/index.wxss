/* 帖子详情页样式 - 修复版 */

.post-detail-container {
  min-height: 100vh;
  background-color: var(--color-bg-page);
  padding-bottom: 160rpx;
}

/* 帖子内容区域 */
.post-content-section {
  background-color: #ffffff;
  border-radius: 0 0 30rpx 30rpx;
  padding: 40rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 帖子头部 */
.user-info-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.info-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

/* 标签样式优化 */
.tag-badge {
  background: linear-gradient(90deg, #ff9800, #ffb74d);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  line-height: 1;
}

.tag-help {
  background: linear-gradient(90deg, #e64340, #ff6b6b);
}

.tag-share {
  background: linear-gradient(90deg, #00b42a, #34c759);
}

.tag-icon {
  margin-right: 4rpx;
  font-size: 16rpx;
}

.time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time {
  font-size: 24rpx;
  color: #999;
}

/* 删除按钮样式 - 红色圆角 */
.delete-btn {
  background-color: #ff4d4f;
  color: #ffffff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-left: 20rpx;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 30rpx;
}

.content-text {
  font-size: 32rpx;
  line-height: 1.6;
  color: #333;
  word-break: break-word;
}

/* 内容体容器 */
.content-body {
  padding: 0 10rpx;
  margin-bottom: 40rpx;
}

/* 1. 用户文字区 */
.user-text-section {
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-text {
  font-size: 34rpx;
  color: #1a1a1a;
  line-height: 1.6;
  font-weight: 500;
}

/* 2. AI 诊断卡片区 */
.ai-report-card {
  background-color: #f7f9fc;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 1rpx solid #e6ebf5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.ai-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed #ccd7e8;
}

.ai-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
}

.ai-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #002fa7;
  margin-left: 10rpx;
}

.ai-content {
  font-size: 30rpx;
  color: #555;
  line-height: 1.7;
  text-align: justify;
}

.recognition-report-card {
  background-color: #f1f5ff;
  border-radius: 16rpx;
  padding: 26rpx;
  border: 1rpx solid #d9e4ff;
  box-shadow: 0 4rpx 12rpx rgba(0, 47, 167, 0.04);
}

.recognition-report-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx dashed #c7d7ff;
}

.recognition-report-icon {
  font-size: 34rpx;
  margin-right: 12rpx;
}

.recognition-report-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #002fa7;
}

.recognition-report-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 0;
}

.recognition-report-label {
  font-size: 25rpx;
  color: #6b7a99;
}

.recognition-report-value {
  font-size: 28rpx;
  color: #0a2463;
  font-weight: 700;
  text-align: right;
}

.recognition-report-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  flex: 1;
}

.recognition-report-tag {
  max-width: 100%;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background-color: #eef4ff;
  color: #0a2463;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  word-break: break-word;
}

.scheme-report-card {
  background-color: #fffaf0;
  border-radius: 16rpx;
  padding: 28rpx;
  border: 1rpx solid #f1dfb8;
  box-shadow: 0 4rpx 12rpx rgba(120, 80, 0, 0.05);
}

.scheme-report-header {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx dashed #dfc98f;
}

.scheme-report-icon {
  font-size: 34rpx;
  margin-right: 12rpx;
}

.scheme-report-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #8a5a00;
}

.ramp-problem-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.ramp-problem-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background-color: #fff3d1;
  color: #8a5a00;
  font-size: 22rpx;
}

.scheme-card {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1dfb8;
}

.scheme-card:last-child {
  border-bottom: 0;
}

.scheme-card-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.scheme-card-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.scheme-card-code {
  min-width: 96rpx;
  color: #002fa7;
  font-size: 28rpx;
  font-weight: 700;
}

.scheme-card-title {
  color: #333;
  font-size: 27rpx;
  line-height: 1.4;
}

.scheme-card-status {
  flex-shrink: 0;
  font-size: 23rpx;
  color: #178a5f;
}

.scheme-card.placeholder .scheme-card-status {
  color: #a36b00;
}

.scheme-file-groups {
  margin-top: 16rpx;
  padding-left: 8rpx;
}

.scheme-focused-sections {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.scheme-focus-section {
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.78);
  border: 1rpx solid #f3e7c8;
}

.scheme-file-group {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background-color: rgba(255, 255, 255, 0.72);
  border: 1rpx solid #f3e7c8;
}

.scheme-group-title {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
  color: #8a5a00;
  font-size: 25rpx;
  font-weight: 700;
}

.scheme-section-title {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
  color: #8a5a00;
  font-size: 25rpx;
  font-weight: 700;
}

.scheme-group-count {
  flex-shrink: 0;
  color: #9a7a38;
  font-size: 22rpx;
  font-weight: 400;
}

.scheme-file-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx 0;
  border-top: 1rpx solid #f5ecd6;
}

.scheme-file-name {
  flex: 1;
  min-width: 0;
  color: #333;
  font-size: 24rpx;
  line-height: 1.35;
  word-break: break-all;
}

.scheme-file-type {
  flex-shrink: 0;
  color: #178a5f;
  font-size: 22rpx;
}

.scheme-file-row.engineering .scheme-file-type {
  color: #a36b00;
}

.scheme-tag-summary {
  background-color: #fffdf7;
}

.scheme-summary-line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 8rpx 0;
}

.scheme-summary-label {
  width: 112rpx;
  flex-shrink: 0;
  color: #9a7a38;
  font-size: 23rpx;
}

.scheme-summary-value {
  flex: 1;
  color: #3d3420;
  font-size: 24rpx;
  line-height: 1.45;
}

.scheme-card-empty {
  display: block;
  color: #8a6d3b;
  font-size: 27rpx;
  line-height: 1.6;
}

/* 用户建议块 */
.user-suggestion-block {
  margin-bottom: 30rpx;
  background-color: #f5f5f5;
  border-left: 6rpx solid #002fa7;
  padding: 24rpx;
  border-radius: 8rpx;
}

.suggestion-blue-line {
  width: 6rpx;
  height: 100%;
  background-color: #002fa7;
}

.suggestion-content {
  display: flex;
  gap: 16rpx;
}

.suggestion-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #002fa7;
  flex-shrink: 0;
}

.suggestion-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  word-break: break-word;
}

/* 定位信息卡片 */
.location-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  background-color: rgba(0, 47, 167, 0.05);
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.location-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.location-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.location-pin-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.location-label {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: bold;
}

.location-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  word-break: break-word;
}

.detail-address-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  word-break: break-word;
  padding-left: 20rpx;
  border-left: 3rpx solid #002fa7;
}

.coordinate-text {
  font-size: 24rpx;
  color: #777;
  line-height: 1.5;
  word-break: break-word;
}

/* 图片展示 */
.post-images {
  margin-bottom: 30rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.post-image {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

/* 底部操作栏 */
.post-actions {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-top: 30rpx;
  border-top: 2rpx solid var(--color-border);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background-color: transparent;
  transition: background-color var(--transition-fast);
  min-width: 140rpx;
  justify-content: center;
}

.action-btn:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.action-btn.liked {
  background-color: rgba(230, 67, 64, 0.08);
}

.action-btn.collected {
  background-color: rgba(255, 215, 0, 0.12);
}

.action-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
}

.action-icon.heart-icon,
.action-icon.star-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.like-btn.liked .action-text {
  color: #ff4d4f;
}

.collect-btn.collected .action-text {
  color: var(--color-accent);
}

/* 评论区 */
.comments-section {
  background-color: #ffffff;
  border-radius: 30rpx 30rpx;
  padding: 40rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.comment-count {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 评论列表 */
.comments-list {
  margin-bottom: 40rpx;
}

.comment-item {
  margin-bottom: 40rpx;
}

/* 主评论 */
.main-comment {
  display: flex;
  margin-bottom: 20rpx;
}

.comment-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid var(--color-accent);
  flex-shrink: 0;
  cursor: pointer;
  transition: all 0.3s ease;
}

.comment-avatar:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.comment-content {
  flex: 1;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.comment-author-wrapper {
  flex: 1;
  min-width: 0;
}

.comment-author {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.comment-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.comment-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
  word-break: break-word;
  margin-bottom: 15rpx;
}

.comment-actions {
  display: flex;
  gap: 20rpx;
}

.comment-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background-color: var(--color-bg-page);
  transition: background-color var(--transition-fast);
}

.comment-action:active {
  background-color: var(--color-border);
}

.comment-action.liked {
  background-color: rgba(230, 67, 64, 0.08);
}

.comment-action .action-icon {
  width: 24rpx;
  height: 24rpx;
}

.comment-action .action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.like-action.liked .action-text {
  color: var(--color-error);
}

.reply-action.delete-action,
.comment-action.delete-action {
  background-color: rgba(255, 77, 77, 0.08);
}

.reply-action.delete-action .action-text,
.comment-action.delete-action .action-text {
  color: var(--color-error);
}

/* 回复列表 */
.replies-list {
  margin-left: 100rpx;
  border-left: 4rpx solid var(--color-border);
  padding-left: 20rpx;
}

.reply-item {
  display: flex;
  margin-bottom: 20rpx;
}

.reply-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
  border: 2rpx solid var(--color-accent);
  flex-shrink: 0;
  cursor: pointer;
  transition: all 0.3s ease;
}

.reply-avatar:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.reply-content {
  flex: 1;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.reply-author-wrapper {
  flex: 1;
  min-width: 0;
}

.reply-author {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.reply-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.reply-text {
  font-size: 26rpx;
  line-height: 1.4;
  color: #333;
  word-break: break-word;
  margin-bottom: 10rpx;
}

.reply-actions {
  display: flex;
  gap: 15rpx;
}

.reply-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 15rpx;
  background-color: var(--color-bg-page);
  transition: background-color var(--transition-fast);
}

.reply-action:active {
  background-color: var(--color-border);
}

.reply-action.liked {
  background-color: rgba(230, 67, 64, 0.08);
}

.reply-action .action-icon {
  width: 20rpx;
  height: 20rpx;
}

.reply-action .action-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.like-action.liked .action-text {
  color: var(--color-error);
}

/* 空评论状态 */
.empty-comments {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  margin-bottom: 15rpx;
  font-weight: bold;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--color-text-disabled);
}

/* 底部评论输入栏 - 关键修复 */
.footer-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 110rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.input-wrapper {
  flex: 1;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin-right: 20rpx;
}

.input-field {
  width: 100%;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  font-size: 30rpx;
  color: #002fa7;
  font-weight: bold;
  padding: 10rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.loading-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

/* 无障碍优化 */
.action-btn,
.comment-action,
.reply-action,
.cancel-btn,
.submit-btn {
  min-height: 60rpx;
  min-width: 80rpx;
}

.fixed-comment-btn {
  min-height: 80rpx;
  min-width: 200rpx;
}

/* 高对比度模式支持 */
@media (prefers-contrast: high) {
  .post-content-section,
  .comments-section {
    border: 3rpx solid var(--color-primary);
  }

  .action-btn,
  .comment-action,
  .reply-action {
    border: 2rpx solid var(--color-primary);
  }
}

/* 大字体模式支持 */
@media (prefers-font-size: large) {
  .content-text,
  .comment-text,
  .reply-text {
    font-size: 36rpx;
    line-height: 1.8;
  }

  .user-name,
  .comment-author,
  .reply-author {
    font-size: 40rpx;
  }

  .action-text {
    font-size: 32rpx;
  }
}

/* ========================================
   🆕 专业用户操作区样式
   ======================================== */

.professional-actions {
  margin-top: 40rpx;
}

.section-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e5e7eb 20%, #e5e7eb 80%, transparent);
  margin-bottom: 30rpx;
}

.professional-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.professional-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pro-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.3s;
  border: 2rpx solid;
}

.pro-btn:active {
  transform: scale(0.95);
}

.pro-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.pro-text {
  font-size: 26rpx;
}

/* 核实问题按钮 */
.verify-btn {
  background: linear-gradient(135deg, #10b981, #34d399);
  border-color: #10b981;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

.verified-badge {
  background: #ecfdf5;
  border-color: #10b981;
  color: #10b981;
  cursor: default;
}

.verified-badge:active {
  transform: none;
}

/* 设计方案按钮 */
.design-btn {
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  border-color: #3b82f6;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.2);
}

/* 提交报价按钮 */
.quote-btn {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
  border-color: #f59e0b;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.2);
}

/* 创建项目按钮 */
.project-btn {
  background: linear-gradient(135deg, #8b5cf6, #a78bfa);
  border-color: #8b5cf6;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(139, 92, 246, 0.2);
}

/* 联系用户按钮 */
.contact-btn {
  background: linear-gradient(135deg, #ef4444, #f87171);
  border-color: #ef4444;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.2);
}

/* 关注按钮样式 */
.follow-btn {
  background: linear-gradient(135deg, #10b981, #34d399);
  color: white;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-left: 12rpx;
  transition: all 0.3s;
}

.follow-btn.followed {
  background: #f3f4f6;
  color: #6b7280;
}

.follow-btn:active {
  transform: scale(0.95);
}

.tag-demand {
  background: #eff6ff;
  color: #1d4ed8;
}

.demand-info-card {
  margin: 20rpx 0;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f8fbff;
  border: 2rpx solid #dbeafe;
}

.demand-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.demand-info-label {
  color: #64748b;
  font-size: 26rpx;
}

.demand-info-value {
  color: #172554;
  font-size: 28rpx;
  font-weight: 700;
}

.demand-info-value.urgency-high {
  color: #ef4444;
}

.demand-info-value.urgency-medium {
  color: #f59e0b;
}

.demand-info-value.urgency-low {
  color: #22c55e;
}

/* 状态徽章 */
.status-badge {
  margin-left: auto;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-processing {
  background: #dbeafe;
  color: #1e40af;
}

.status-accepted {
  background: #ede9fe;
  color: #5b21b6;
}

.status-constructing {
  background: #dbeafe;
  color: #1e40af;
}

.status-accepting {
  background: #fef3c7;
  color: #92400e;
}

.status-completed {
  background: #d1fae5;
  color: #065f46;
}

/* 关联内容展示 */
.linked-content {
  margin-bottom: 20rpx;
}

.linked-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.3s;
}

.linked-item:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.linked-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.linked-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.linked-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.linked-desc {
  font-size: 24rpx;
  color: #6b7280;
}

.linked-arrow {
  font-size: 32rpx;
  color: #9ca3af;
  font-weight: 300;
}

/* 暂无关联内容 */
.no-linked-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border: 2rpx dashed #d1d5db;
}

.no-content-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.6;
}

.no-content-text {
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
}

/* 更新进度按钮 */
.update-btn {
  background: linear-gradient(135deg, #06b6d4, #22d3ee);
  border-color: #06b6d4;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(6, 182, 212, 0.2);
}

/* 确认完成按钮 */
.complete-btn {
  background: linear-gradient(135deg, #10b981, #34d399);
  border-color: #10b981;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

/* 已完成徽章 */
.completed-badge {
  background: #ecfdf5;
  border-color: #10b981;
  color: #10b981;
  cursor: default;
}

.completed-badge:active {
  transform: none;
}
