<view class="post-detail-container">
  <!-- 帖子详情内容 -->
  <view class="post-content-section" wx:if="{{post}}">
    <!-- 帖子头部 -->
    <view class="user-info-card">
      <image class="avatar" src="{{post.userInfo.avatarUrl || '/images/zhi.png'}}" mode="aspectFill" aria-hidden="true" bindtap="navigateToProfile" data-id="{{post._openid}}"></image>
      
      <view class="info-right">
        <!-- 第一行：名字 + 标签 -->
        <view class="name-row">
          <view bindtap="navigateToProfile" data-id="{{post._openid}}">
            <user-name 
              nickName="{{post.userInfo.nickName}}" 
              userType="{{post.userType}}"
              inline="{{true}}"
            />
          </view>
          <view class="follow-btn {{isFollowing ? 'followed' : ''}}" bindtap="toggleFollow" wx:if="{{!post.isOwner}}">
            {{isFollowing ? '已关注' : '关注'}}
          </view>
          <view class="tag-badge" wx:if="{{post.type === 'issue'}}">
            <text class="tag-icon">🚧</text>
            <text>{{post.categoryName || '随手拍'}}</text>
          </view>
          <view class="tag-badge tag-demand" wx:elif="{{post.type === 'demand'}}">
            <text class="tag-icon">📌</text>
            <text>改造需求</text>
          </view>
          <view class="tag-badge" wx:elif="{{post.type === 'case'}}">
            <text class="tag-icon">🏗️</text>
            <text>{{post.categoryName || '案例'}}</text>
          </view>
          <view class="tag-badge tag-share" wx:elif="{{post.type === 'community'}}">
            <text class="tag-icon">💬</text>
            <text>社区</text>
          </view>
          <view class="tag-badge tag-help" wx:elif="{{post.type === 'help'}}">
            <text class="tag-icon">❓</text>
            <text>求助</text>
          </view>
          <view class="tag-badge tag-share" wx:elif="{{post.type === 'share'}}">
            <text class="tag-icon">💬</text>
            <text>分享</text>
          </view>
        </view>
        
        <!-- 第二行：时间 + 删除按钮 -->
        <view class="time-row">
          <text class="time">{{post.createTime}}</text>
          
          <!-- 删除按钮：红色圆角样式（作者或管理员可见） -->
          <view 
            class="delete-btn" 
            bindtap="deletePost" 
            wx:if="{{post.canDelete}}"
            data-postid="{{post._id}}"
            aria-role="button"
            aria-label="删除帖子"
          >
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 帖子内容区 -->
    <view class="content-body">
      <!-- 第一部分：用户发布的内容 -->
      <view class="user-text-section">
        <text class="user-text" user-select="true">{{post.content}}</text>
      </view>

      <view class="recognition-report-card" wx:if="{{post.recognizedCategory}}">
        <view class="recognition-report-header">
          <text class="recognition-report-icon">🔎</text>
          <text class="recognition-report-title">识别结果</text>
        </view>
        <view class="recognition-report-row">
          <text class="recognition-report-label">大类</text>
          <text class="recognition-report-value">{{post.recognizedCategory}}</text>
        </view>
        <view class="recognition-report-row" wx:if="{{post.recognizedSubtypes.length}}">
          <text class="recognition-report-label">子类</text>
          <view class="recognition-report-tags">
            <text
              class="recognition-report-tag"
              wx:for="{{post.recognizedSubtypes}}"
              wx:key="*this"
            >{{item}}</text>
          </view>
        </view>
        <view class="recognition-report-row" wx:if="{{post.recognitionConfidenceText}}">
          <text class="recognition-report-label">置信度</text>
          <text class="recognition-report-value">{{post.recognitionConfidenceText}}</text>
        </view>
      </view>

      <!-- 第二部分：AI 诊断卡片 (完全独立，带背景色) -->
      <view class="ai-report-card" wx:if="{{post.aiDiagnosis || post.aiSolution}}">
        <view class="ai-header">
          <text class="ai-icon">🤖</text>
          <text class="ai-title">AI 智能诊断</text>
        </view>
        <view class="ai-content">
          <text user-select="true">{{post.aiDiagnosis || post.aiSolution}}</text>
        </view>
      </view>

      <view class="demand-info-card" wx:if="{{post.type === 'demand'}}">
        <view class="demand-info-row">
          <text class="demand-info-label">需求状态</text>
          <text class="demand-info-value">{{post.statusText}}</text>
        </view>
        <view class="demand-info-row" wx:if="{{post.urgencyText}}">
          <text class="demand-info-label">紧急程度</text>
          <text class="demand-info-value urgency-{{post.urgency}}">{{post.urgencyText}}</text>
        </view>
        <view class="demand-info-row" wx:if="{{post.community}}">
          <text class="demand-info-label">所属社区</text>
          <text class="demand-info-value">{{post.community}}</text>
        </view>
      </view>

      <view class="scheme-report-card" wx:if="{{post.hasSchemePanel}}">
        <view class="scheme-report-header">
          <text class="scheme-report-icon">📐</text>
          <text class="scheme-report-title">匹配改造方案</text>
        </view>
        <view class="ramp-problem-tags" wx:if="{{post.rampProblems && post.rampProblems.length}}">
          <text
            class="ramp-problem-tag"
            wx:for="{{post.rampProblems}}"
            wx:key="*this"
          >{{item}}</text>
        </view>
        <block wx:if="{{post.matchedSchemes && post.matchedSchemes.length}}">
          <view
            class="scheme-card {{scheme.resourceStatus === 'placeholder' ? 'placeholder' : 'ready'}}"
            wx:for="{{post.matchedSchemes}}"
            wx:for-item="scheme"
            wx:for-index="schemeIndex"
            wx:key="code"
          >
            <view
              class="scheme-card-summary"
              data-index="{{schemeIndex}}"
              data-status="{{scheme.resourceStatus}}"
              data-code="{{scheme.code}}"
              bindtap="handleSchemeTap"
              aria-role="button"
              aria-label="{{scheme.code}} {{scheme.resourceStatus === 'placeholder' ? '暂无方案文件' : '查看首个方案文件'}}"
            >
              <view class="scheme-card-main">
                <text class="scheme-card-code">{{scheme.code}}</text>
                <text class="scheme-card-title">{{scheme.title}}</text>
              </view>
              <text class="scheme-card-status" wx:if="{{scheme.resourceStatus === 'placeholder'}}">暂无方案文件</text>
              <text class="scheme-card-status" wx:else>{{scheme.totalFileCount || 0}}个文件</text>
            </view>
            <view class="scheme-focused-sections">
              <view class="scheme-focus-section" wx:if="{{scheme.displaySections && scheme.displaySections.drawingFiles && scheme.displaySections.drawingFiles.length}}">
                <view class="scheme-section-title">
                  <text>施工图纸</text>
                  <text class="scheme-group-count">{{scheme.displaySections.drawingFiles.length}}个文件</text>
                </view>
                <view
                  class="scheme-file-row {{file.fileType === 'engineering' ? 'engineering' : 'preview'}}"
                  wx:for="{{scheme.displaySections.drawingFiles}}"
                  wx:for-item="file"
                  wx:for-index="fileIndex"
                  wx:key="cloudPath"
                  data-scheme-index="{{schemeIndex}}"
                  data-section="drawingFiles"
                  data-file-index="{{fileIndex}}"
                  bindtap="handleSchemeDisplayFileTap"
                  aria-role="button"
                  aria-label="{{file.name}}"
                >
                  <text class="scheme-file-name">{{file.name}}</text>
                  <text class="scheme-file-type">{{file.fileType === 'engineering' ? '工程文件' : '预览'}}</text>
                </view>
              </view>

              <view class="scheme-focus-section scheme-tag-summary" wx:if="{{scheme.schemeSummary}}">
                <view class="scheme-section-title">
                  <text>方案标签卡</text>
                </view>
                <view class="scheme-summary-line" wx:if="{{scheme.schemeSummary.matchedSubtypesText}}">
                  <text class="scheme-summary-label">适用问题</text>
                  <text class="scheme-summary-value">{{scheme.schemeSummary.matchedSubtypesText}}</text>
                </view>
                <view class="scheme-summary-line" wx:if="{{scheme.schemeSummary.designFocus}}">
                  <text class="scheme-summary-label">改造要点</text>
                  <text class="scheme-summary-value">{{scheme.schemeSummary.designFocus}}</text>
                </view>
                <view
                  class="scheme-file-row preview"
                  wx:if="{{scheme.displaySections.tagCardFiles && scheme.displaySections.tagCardFiles.length}}"
                  wx:for="{{scheme.displaySections.tagCardFiles}}"
                  wx:for-item="file"
                  wx:for-index="fileIndex"
                  wx:key="cloudPath"
                  data-scheme-index="{{schemeIndex}}"
                  data-section="tagCardFiles"
                  data-file-index="{{fileIndex}}"
                  bindtap="handleSchemeDisplayFileTap"
                  aria-role="button"
                  aria-label="{{file.name}}"
                >
                  <text class="scheme-file-name">{{file.name}}</text>
                  <text class="scheme-file-type">标签卡</text>
                </view>
              </view>

              <view class="scheme-focus-section" wx:if="{{scheme.displaySections && scheme.displaySections.materialTableFiles && scheme.displaySections.materialTableFiles.length}}">
                <view class="scheme-section-title">
                  <text>施工物料表</text>
                  <text class="scheme-group-count">{{scheme.displaySections.materialTableFiles.length}}个文件</text>
                </view>
                <view
                  class="scheme-file-row preview"
                  wx:for="{{scheme.displaySections.materialTableFiles}}"
                  wx:for-item="file"
                  wx:for-index="fileIndex"
                  wx:key="cloudPath"
                  data-scheme-index="{{schemeIndex}}"
                  data-section="materialTableFiles"
                  data-file-index="{{fileIndex}}"
                  bindtap="handleSchemeDisplayFileTap"
                  aria-role="button"
                  aria-label="{{file.name}}"
                >
                  <text class="scheme-file-name">{{file.name}}</text>
                  <text class="scheme-file-type">物料表</text>
                </view>
              </view>
            </view>
          </view>
        </block>
        <text class="scheme-card-empty" wx:else>{{post.schemeMessage || '暂无方案'}}</text>
      </view>
    </view>

    <!-- 定位信息 -->
    <view class="location-card" wx:if="{{post.address || post.formattedAddress || post.locationCoordinateText}}">
      <image class="location-icon" src="/images/flag.png" aria-hidden="true"></image>
      <view class="location-info">
        <view class="location-header">
          <image class="location-pin-icon" src="/images/flag.png" aria-hidden="true"></image>
          <text class="location-label">位置</text>
        </view>
        <text class="location-text">{{post.formattedAddress || post.address}}</text>
        <text class="detail-address-text" wx:if="{{post.detailAddress}}">{{post.detailAddress}}</text>
        <text class="coordinate-text" wx:if="{{post.locationCoordinateText}}">{{post.locationCoordinateText}}</text>
      </view>
    </view>

    <!-- 图片展示 -->
    <view class="post-images" wx:if="{{post.images && post.images.length > 0}}">
      <view class="image-grid">
        <image 
          class="post-image" 
          wx:for="{{post.images}}" 
          wx:key="index" 
          wx:for-item="img"
          src="{{img}}" 
          mode="aspectFill"
          bindtap="previewImage"
          data-current="{{img}}"
          data-urls="{{post.images}}"
          aria-label="帖子图片{{index + 1}}"
        ></image>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="post-actions">
      <view 
        class="action-btn like-btn {{isLiked ? 'liked' : ''}}" 
        bindtap="likePost"
        aria-role="button"
        aria-label="{{isLiked ? '取消点赞' : '点赞'}}，当前{{likeCount}}个赞"
      >
        <text class="action-icon heart-icon">{{isLiked ? '❤️' : '🤍'}}</text>
        <text class="action-text {{isLiked ? 'liked-text' : ''}}">{{likeCount}}</text>
      </view>

      <view 
        class="action-btn comment-btn" 
        bindtap="showCommentInput"
        aria-role="button"
        aria-label="发表评论，当前{{post.stats.comment}}条评论"
      >
        <text class="action-icon comment-icon">💬</text>
        <text class="action-text">{{post.stats.comment}}</text>
      </view>

      <view 
        class="action-btn collect-btn {{isCollected ? 'collected' : ''}}" 
        bindtap="toggleCollect"
        aria-role="button"
        aria-label="{{isCollected ? '取消收藏' : '收藏'}}，当前{{collectCount}}人收藏"
      >
        <text class="action-icon star-icon">{{isCollected ? '⭐' : '☆'}}</text>
        <text class="action-text">{{collectCount}}</text>
      </view>
    </view>

    <!-- 🆕 专业用户操作区（仅问题帖显示） -->
    <view class="professional-actions" wx:if="{{showProfessionalActions}}">
      <view class="section-divider"></view>
      <view class="professional-title">
        <text class="title-icon">🔧</text>
        <text class="title-text">专业操作</text>
        <text class="status-badge status-{{post.status}}">
          {{post.statusText}}
        </text>
      </view>
      
      <!-- 关联内容展示（所有角色都能看到） -->
      <view class="linked-content">
        <!-- 设计方案 -->
        <view class="linked-item" wx:if="{{proposalCount > 0}}" bindtap="viewProposalList">
          <text class="linked-icon">📐</text>
          <view class="linked-info">
            <text class="linked-title">{{post.type === 'demand' ? '报名方案' : '设计方案'}}</text>
            <text class="linked-desc">已有 {{proposalCount}} 个{{post.type === 'demand' ? '报名方案' : '设计方案'}}</text>
          </view>
          <text class="linked-arrow">›</text>
        </view>
        
        <!-- 施工项目（显示施工节点进度） -->
        <view class="linked-item" wx:if="{{linkedProject}}" bindtap="viewProject">
          <text class="linked-icon">🏗️</text>
          <view class="linked-info">
            <text class="linked-title">施工项目</text>
            <text class="linked-desc">{{linkedProject.contractorName || '施工方'}} · {{linkedProject.currentStage || '准备阶段'}}</text>
          </view>
          <text class="linked-arrow">›</text>
        </view>
        
        <!-- 暂无关联内容提示 -->
        <view class="no-linked-content" wx:if="{{proposalCount === 0 && !linkedProject}}">
          <text class="no-content-icon">📋</text>
          <text class="no-content-text">{{post.type === 'demand' ? '暂无报名方案或施工项目' : '暂无关联的设计方案或施工项目'}}</text>
        </view>
      </view>
      
      <!-- 操作按钮区（根据角色显示） -->
      <view class="professional-buttons">
        <!-- 设计师功能 -->
        <block wx:if="{{canSubmitProposal}}">
          <!-- 添加设计方案按钮 -->
          <view 
            class="pro-btn design-btn" 
            bindtap="addDesignSolution"
            wx:if="{{post.type === 'demand' || proposalCount === 0}}"
          >
            <text class="pro-icon">📐</text>
            <text class="pro-text">{{post.type === 'demand' ? '提交报名方案' : '添加设计方案'}}</text>
          </view>
        </block>
        
        <!-- 施工方功能 -->
        <block wx:if="{{isContractor}}">
          <!-- 创建项目按钮 -->
          <view 
            class="pro-btn project-btn" 
            bindtap="createProject"
            wx:if="{{!linkedProject}}"
          >
            <text class="pro-icon">🏗️</text>
            <text class="pro-text">创建项目</text>
          </view>
          
          <!-- 更新施工节点按钮 -->
          <view 
            class="pro-btn update-btn" 
            bindtap="updateProjectNode"
            wx:if="{{linkedProject && (post.status === 'processing' || post.status === 'constructing' || post.status === 'accepting')}}"
          >
            <text class="pro-icon">📸</text>
            <text class="pro-text">更新施工节点</text>
          </view>
        </block>
        
        <!-- 施工方功能 -->
        <block wx:if="{{isContractor}}">
          <!-- 查看联系方式按钮 -->
          <view 
            class="pro-btn contact-btn" 
            bindtap="viewContactInfo"
          >
            <text class="pro-icon">📞</text>
            <text class="pro-text">查看联系方式</text>
          </view>
        </block>
        
        <!-- 社区工作者功能 -->
        <block wx:if="{{isCommunityWorker}}">
          <!-- 查看联系方式按钮 -->
          <view 
            class="pro-btn contact-btn" 
            bindtap="viewContactInfo"
          >
            <text class="pro-icon">📞</text>
            <text class="pro-text">查看联系方式</text>
          </view>
          
          <!-- 确认完成按钮 -->
          <view 
            class="pro-btn complete-btn" 
            bindtap="confirmProjectCompletion"
            wx:if="{{linkedProject && (post.status === 'processing' || post.status === 'constructing' || post.status === 'accepting')}}"
          >
            <text class="pro-icon">✅</text>
            <text class="pro-text">确认项目完成</text>
          </view>
        </block>
        
        <!-- 发帖者功能 -->
        <block wx:if="{{isPostOwner && !isCommunityWorker}}">
          <!-- 确认完成按钮 -->
          <view 
            class="pro-btn complete-btn" 
            bindtap="confirmProjectCompletion"
            wx:if="{{linkedProject && (post.status === 'processing' || post.status === 'constructing' || post.status === 'accepting')}}"
          >
            <text class="pro-icon">✅</text>
            <text class="pro-text">确认项目完成</text>
          </view>
        </block>
        
        <!-- 已完成标识（所有角色都能看到） -->
        <view class="pro-btn completed-badge" wx:if="{{post.status === 'completed'}}">
          <text class="pro-icon">🎉</text>
          <text class="pro-text">项目已完成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comments-section">
    <view class="section-header">
      <text class="section-title">评论</text>
      <text class="comment-count">{{comments.length}}条</text>
    </view>

    <!-- 评论列表 -->
    <view class="comments-list">
      <view class="comment-item" wx:for="{{comments}}" wx:key="_id">
        <!-- 主评论 -->
        <view class="main-comment">
          <image class="comment-avatar" src="{{item.userInfo.avatarUrl || '/images/zhi.png'}}" aria-hidden="true" bindtap="navigateToUserProfile" data-openid="{{item._openid}}"></image>
          <view class="comment-content">
            <view class="comment-header">
              <view class="comment-author-wrapper">
                <user-name 
                  nickName="{{item.userInfo.nickName}}" 
                  userType="{{item.userType}}"
                  inline="{{true}}"
                  vertical="{{true}}"
                />
              </view>
              <text class="comment-time">{{item.createTime}}</text>
            </view>
            <text class="comment-text" user-select="true">{{item.content}}</text>
            <view class="comment-actions">
              <view
                class="comment-action like-action {{item.liked ? 'liked' : ''}}"
                bindtap="likeComment"
                data-commentid="{{item._id}}"
                aria-role="button"
                aria-label="{{item.liked ? '取消点赞' : '点赞'}}评论，当前{{item.likes}}个赞"
              >
                <text class="action-icon heart-icon">{{item.liked ? '❤️' : '🤍'}}</text>
                <text class="action-text">{{item.likes}}</text>
              </view>
              <view
                class="comment-action reply-action"
                bindtap="showCommentInput"
                data-replyto="{{item._id}}"
                data-replyname="{{item.userInfo.nickName}}"
                aria-role="button"
                aria-label="回复{{item.userInfo.nickName}}的评论"
              >
                <text class="action-text">回复</text>
              </view>
              <view
                class="comment-action delete-action"
                wx:if="{{item.canDelete}}"
                bindtap="deleteComment"
                data-commentid="{{item._id}}"
                aria-role="button"
                aria-label="删除评论"
              >
                <text class="action-text">删除</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 回复列表 -->
        <view class="replies-list" wx:if="{{item.replies && item.replies.length > 0}}">
          <view class="reply-item" wx:for="{{item.replies}}" wx:key="_id" wx:for-item="reply">
            <image class="reply-avatar" src="{{reply.userInfo.avatarUrl || '/images/zhi.png'}}" aria-hidden="true" bindtap="navigateToUserProfile" data-openid="{{reply._openid}}"></image>
            <view class="reply-content">
              <view class="reply-header">
                <view class="reply-author-wrapper">
                  <user-name 
                    nickName="{{reply.userInfo.nickName}}" 
                    userType="{{reply.userType}}"
                    inline="{{true}}"
                    vertical="{{true}}"
                  />
                </view>
                <text class="reply-time">{{reply.createTime}}</text>
              </view>
              <text class="reply-text" user-select="true">{{reply.content}}</text>
              <view class="reply-actions">
                <view 
                  class="reply-action like-action {{reply.liked ? 'liked' : ''}}" 
                  bindtap="likeComment" 
                  data-commentid="{{reply._id}}" 
                  data-isreply="true" 
                  data-parentid="{{reply.parentId}}"
                  aria-role="button"
                  aria-label="{{reply.liked ? '取消点赞' : '点赞'}}回复，当前{{reply.likes}}个赞"
                >
                  <text class="action-icon heart-icon">{{reply.liked ? '❤️' : '🤍'}}</text>
                  <text class="action-text">{{reply.likes}}</text>
                </view>
                <view
                  class="reply-action reply-action"
                  bindtap="showCommentInput"
                  data-replyto="{{reply._id}}"
                  data-replyname="{{reply.userInfo.nickName}}"
                  aria-role="button"
                  aria-label="回复{{reply.userInfo.nickName}}的评论"
                >
                  <text class="action-text">回复</text>
                </view>
                <view
                  class="reply-action delete-action"
                  wx:if="{{reply.canDelete}}"
                  bindtap="deleteComment"
                  data-commentid="{{reply._id}}"
                  data-isreply="true"
                  data-parentid="{{reply.parentId}}"
                  aria-role="button"
                  aria-label="删除回复"
                >
                  <text class="action-text">删除</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空评论状态 -->
    <view class="empty-comments" wx:if="{{comments.length === 0}}">
      <image class="empty-icon" src="/images/empty-comments.png" aria-hidden="true"></image>
      <text class="empty-text">暂无评论</text>
      <text class="empty-subtext">快来发表第一条评论吧</text>
    </view>
  </view>

  <!-- 底部评论输入栏 -->
  <view class="footer-input-bar">
    <view class="input-wrapper">
      <input 
        id="comment-input"
        class="input-field" 
        placeholder="{{placeholderText}}" 
        placeholder-style="color: #999;" 
        focus="{{isInputFocus}}"
        bindinput="onCommentInput"
        bindblur="onInputBlur"
        value="{{newComment}}"
        confirm-type="send"
        bindconfirm="submitComment"
        aria-label="评论输入框"
      />
    </view>
    <view class="send-btn" bindtap="submitComment" aria-role="button" aria-label="发送评论">发送</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
