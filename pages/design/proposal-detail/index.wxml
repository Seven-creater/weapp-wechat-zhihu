<view class="container" wx:if="{{!loading && proposal}}">
  <!-- 报名方信息卡片 -->
  <view class="designer-card">
    <image 
      class="designer-avatar" 
      src="{{proposal.designerAvatar || '/images/default-avatar.png'}}" 
      mode="aspectFill"
      bindtap="navigateToDesigner"
    ></image>
    <view class="designer-info">
      <text class="designer-name">{{proposal.designerName || '报名方'}}</text>
      <view class="designer-badge">
        <text class="badge-icon">📐</text>
        <text class="badge-text">{{proposal.submitterType === 'contractor' ? '施工方' : '专业设计师'}}</text>
      </view>
    </view>
  </view>

  <!-- 提交时间 -->
  <view class="time-info">
    <text class="time-label">提交时间：</text>
    <text class="time-value">{{proposal.createTime}}</text>
  </view>

  <!-- 方案描述 -->
  <view class="section">
    <view class="section-title">
      <text class="title-icon">📝</text>
      <text class="title-text">报名方案</text>
    </view>
    <view class="section-content">
      <text class="proposal-desc">{{proposal.description}}</text>
    </view>
  </view>

  <!-- 设计图纸 -->
  <view class="section" wx:if="{{proposal.images && proposal.images.length > 0}}">
    <view class="section-title">
      <text class="title-icon">🖼️</text>
      <text class="title-text">方案图片</text>
    </view>
    <view class="images-grid">
      <image 
        class="design-image" 
        wx:for="{{proposal.images}}" 
        wx:key="index"
        src="{{item}}" 
        mode="aspectFill"
        bindtap="previewImage"
        data-src="{{item}}"
      ></image>
    </view>
  </view>

  <!-- 在线报价 -->
  <view class="section" wx:if="{{proposal.quoteAmount || proposal.budgetAdjustment}}">
    <view class="section-title">
      <text class="title-icon">💰</text>
      <text class="title-text">在线报价</text>
    </view>
    <view class="budget-card">
      <text class="budget-amount">¥{{proposal.quoteAmount || proposal.budgetAdjustment}}</text>
      <text class="budget-note" wx:if="{{proposal.estimateDays}}">预计工期：{{proposal.estimateDays}}天</text>
      <text class="budget-note">可在线沟通后确认最终方案</text>
    </view>
  </view>

  <view class="action-section">
    <button class="contact-btn" bindtap="contactDesigner">
      <text class="btn-text">在线沟通</text>
    </button>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-state" wx:if="{{loading}}">
  <text class="loading-text">加载中...</text>
</view>
