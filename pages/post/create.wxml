<view class="publish-selection-container">
  <view class="selection-card issue" bindtap="onIssueTap">
    <image class="card-icon" src="/images/write.png" mode="aspectFit" />
    <view class="card-content">
      <text class="card-title">发布无障碍随手拍</text>
      <text class="card-desc">上报问题，生成改造方案</text>
    </view>
    <view class="arrow-icon">></view>
  </view>

  <view class="selection-card daily" bindtap="onDemandTap">
    <image class="card-icon" src="/images/write.png" mode="aspectFit" />
    <view class="card-content">
      <text class="card-title">社区改造需求发布</text>
      <text class="card-desc">发布改造需求，邀请方案报名</text>
    </view>
    <view class="arrow-icon">></view>
  </view>
</view>
