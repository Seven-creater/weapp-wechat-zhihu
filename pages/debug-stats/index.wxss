.container {
  padding: 28rpx;
  background: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 38rpx;
  color: #1f2a44;
  font-weight: 700;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #506080;
  margin-top: 8rpx;
}

.meta-card,
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.line {
  display: block;
  font-size: 24rpx;
  color: #2c3e5b;
  line-height: 1.7;
  word-break: break-all;
}

.button-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  column-gap: 14rpx;
  row-gap: 14rpx;
  margin-bottom: 18rpx;
}

.btn {
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  background: #ecf0f7;
  color: #1f2a44;
}

.btn.primary {
  background: #0d6efd;
  color: #ffffff;
}

.btn.danger {
  background: #d7263d;
  color: #ffffff;
}

.card-title {
  display: block;
  font-size: 28rpx;
  color: #1f2a44;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.card-content {
  font-size: 23rpx;
  color: #4c5b77;
  white-space: pre-wrap;
  line-height: 1.7;
  word-break: break-all;
}
