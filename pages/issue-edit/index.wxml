<view class="issue-edit-container">
  <view class="header">
    <view class="back-btn" bindtap="handleCancel" aria-role="button" aria-label="返回">
      <image class="back-icon" src="/images/arrow-right-yellow.png" style="transform: rotate(180deg);"></image>
    </view>
    <text class="title">新建位置</text>
    <view class="header-right"></view>
  </view>

  <view class="section">
    <text class="section-title">问题说明（选填）</text>
    <textarea
      class="description-input"
      placeholder="可以补充问题现状..."
      value="{{description}}"
      maxlength="500"
      show-confirm-bar="false"
      bindinput="onDescriptionInput"
      aria-label="问题说明"
    ></textarea>
    <view class="input-footer">
      <view class="word-count">{{description.length}}/500</view>
      <view 
        class="voice-btn {{isRecording ? 'recording' : ''}}"
        catchtouchstart="streamRecord"
        catchtouchend="endStreamRecord"
        aria-role="button"
        aria-label="{{isRecording ? '正在录音，松开结束' : '按住说话'}}"
      >
        <text class="voice-icon">{{isRecording ? '🎤' : '🎙️'}}</text>
        <text class="voice-text">{{isRecording ? '录音中' : '按住说话'}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">现场照片</text>
      <text class="section-subtitle">{{images.length}}/9</text>
    </view>
    <view class="image-list">
      <view
        class="image-item"
        wx:for="{{images}}"
        wx:key="index"
        aria-role="button"
        aria-label="图片{{index + 1}}"
      >
        <image
          class="uploaded-image"
          src="{{item.path}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-src="{{item.path}}"
        ></image>
        <view class="remove-btn" bindtap="removeImage" data-index="{{index}}" aria-role="button" aria-label="删除图片">
          <text class="remove-icon" aria-hidden="true">×</text>
        </view>
      </view>
      <view class="add-image-btn" wx:if="{{images.length < 9}}" bindtap="chooseImage" aria-role="button" aria-label="添加图片">
        <image class="add-icon" src="/images/add-image.png" aria-hidden="true"></image>
        <text class="add-text">继续添加</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">AI 识别结果</text>
    <text class="category-required">*</text>
    <view class="recognition-card" wx:if="{{recognizedCategory}}">
      <view class="recognition-main">
        <view class="recognition-category" bindtap="onRecognitionCategoryTap" aria-role="button" aria-label="双击修改子类">
          <text class="recognition-label">大类</text>
          <text class="recognition-value">{{recognizedCategory}}</text>
        </view>
        <view class="recognition-subtype">
          <text class="recognition-label">子类</text>
          <view class="recognition-tags">
            <text
              class="recognition-tag"
              wx:for="{{recognizedSubtypes}}"
              wx:key="*this"
            >{{item}}</text>
          </view>
        </view>
        <view class="recognition-confidence">
          <text class="recognition-label">置信度</text>
          <text class="recognition-value">{{recognitionConfidenceText}}</text>
        </view>
      </view>
      <view class="recognition-actions">
        <text class="recognition-hint">双击大类可修正子类</text>
        <view class="ai-btn" bindtap="recognizePrimaryImage" aria-role="button" aria-label="重新识别">
          <text>重新识别</text>
        </view>
      </view>
    </view>
    <view class="recognition-empty" wx:else>
      <text>{{recognitionStatus === 'failed' ? recognitionError : (recognizingImage ? '正在识别，请稍候...' : '请选择现场照片，系统会自动识别设施类型')}}</text>
      <view
        class="ai-btn recognition-retry"
        wx:if="{{recognitionStatus === 'failed' && images.length > 0 && !recognizingImage}}"
        bindtap="recognizePrimaryImage"
        aria-role="button"
        aria-label="重新识别"
      >
        <text>重新识别</text>
      </view>
    </view>

    <view class="subtype-picker" wx:if="{{showSubtypePicker}}">
      <view class="subtype-picker-header">
        <text class="subtype-picker-title">选择{{recognizedCategory}}子类（可多选）</text>
        <text class="subtype-picker-close" bindtap="closeSubtypePicker">关闭</text>
      </view>
      <view class="subtype-grid">
        <view
          class="subtype-item {{item.selected ? 'active' : ''}}"
          wx:for="{{subtypeOptions}}"
          wx:key="name"
          data-subtype="{{item.name}}"
          bindtap="onSubtypeSelect"
          aria-role="button"
          aria-label="{{item.selected ? '取消' : '选择'}}{{item.name}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="scheme-match-box" wx:if="{{recognizedCategory}}">
      <block wx:if="{{matchedSchemes.length > 0}}">
        <view
          class="scheme-match-item {{item.resourceStatus === 'placeholder' ? 'placeholder' : 'ready'}}"
          wx:for="{{matchedSchemes}}"
          wx:key="code"
        >
          <text class="scheme-code">{{item.code}}</text>
          <text class="scheme-name">{{item.title}}</text>
          <text class="scheme-status" wx:if="{{item.resourceStatus === 'ready'}}">{{item.totalFileCount || 0}}个文件</text>
          <text class="scheme-status" wx:else>暂无方案文件</text>
        </view>
      </block>
      <text class="scheme-empty" wx:else>{{schemeMessage}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">发布到哪个社区</text>
    <text class="category-required">*</text>
    <view class="category-grid">
      <view
        class="category-item {{selectedCommunity === item ? 'active' : ''}}"
        wx:for="{{communityOptions}}"
        wx:key="*this"
        data-community="{{item}}"
        bindtap="onCommunitySelect"
        aria-role="button"
        aria-label="{{item}}"
      >
        <text class="category-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">联系方式（选填）：</text>
    <input
      class="contact-input"
      placeholder="该设施联系方式（如有人想咨询可以拨打）"
      value="{{contactPhone}}"
      bindinput="onContactPhoneInput"
      bindblur="onContactPhoneBlur"
      type="text"
      aria-label="联系电话"
    />
    <text class="contact-hint">* 填写后他人可一键拨打联系您，非必填</text>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">位置信息</text>
      <view class="reselect-btn" bindtap="chooseLocation" aria-role="button" aria-label="重新定位">
        <text>重新选点</text>
      </view>
    </view>
    <text class="location-text">{{formattedAddress || address || '暂未选择位置'}}</text>
    <input
      class="detail-address-input"
      placeholder="请输入详细地址与门牌号（如：3号楼2单元101室）"
      value="{{detailAddress}}"
      bindinput="onDetailAddressInput"
      type="text"
      aria-label="详细地址与门牌号"
    />
  </view>

  <view class="footer-actions">
    <button class="submit-btn" bindtap="submitIssue" aria-label="发布到社区">
      发布到社区
    </button>
  </view>

  <view class="loading-mask" wx:if="{{recognizingImage || submitting}}">
    <view class="loading-content">
      <image class="loading-icon" src="/images/loading.gif" aria-hidden="true"></image>
      <text class="loading-text">{{recognizingImage ? 'AI 识别中...' : '提交中...'}} </text>
    </view>
  </view>
</view>
