page {
  background-color: #0a2463;
}

.issue-edit-container {
  padding: 30rpx;
  color: #ffffff;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  color: #0a2463;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.section-subtitle {
  font-size: 24rpx;
  color: #6b7a99;
}

.description-input {
  min-height: 180rpx;
  font-size: 28rpx;
  color: #0a2463;
}

.suggestion-input {
  min-height: 120rpx;
  font-size: 28rpx;
  color: #0a2463;
  background-color: #f8f8f8;
  border: 2rpx dashed #cccccc;
  border-radius: 12rpx;
  padding: 20rpx;
}

.word-count {
  text-align: right;
  font-size: 22rpx;
  color: #8a96ad;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.voice-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background-color: #ffd700;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #0a2463;
  transition: all 0.3s;
  min-height: 50rpx;
  min-width: 140rpx;
}

.voice-btn:active {
  background-color: #e6c200;
  transform: scale(0.95);
}

.voice-btn.recording {
  background-color: #ff4444;
  color: #ffffff;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

.voice-icon {
  font-size: 28rpx;
}

.voice-text {
  font-size: 22rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background-color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
}

.remove-icon {
  font-size: 24rpx;
}

.add-image-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #c7d1e6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #6b7a99;
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 10rpx;
}

.section-title {
  margin-right: 16rpx;
}

.section-title + .category-required {
  margin-left: 0;
}

.category-required {
  display: inline-block;
  margin-left: 6rpx;
  font-size: 24rpx;
  color: #ff4d4f;
  vertical-align: middle;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
}

.category-item {
  background-color: #ffffff;
  border-radius: 18rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  border: 2rpx solid #e6ecf5;
  box-shadow: 0 6rpx 16rpx rgba(10, 36, 99, 0.08);
}

.category-item.active {
  border-color: #002fa7;
  box-shadow: 0 8rpx 20rpx rgba(0, 47, 167, 0.18);
}

.category-text {
  font-size: 26rpx;
  color: #0a2463;
}

.recognition-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: #f1f5ff;
  border: 2rpx solid #d9e4ff;
}

.recognition-main {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.recognition-category,
.recognition-subtype,
.recognition-confidence {
  min-height: 96rpx;
  border-radius: 14rpx;
  background-color: #ffffff;
  padding: 14rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border: 1rpx solid #e6ecf5;
}

.recognition-label {
  font-size: 21rpx;
  color: #6b7a99;
  margin-bottom: 8rpx;
}

.recognition-value {
  font-size: 27rpx;
  color: #0a2463;
  font-weight: 700;
  line-height: 1.3;
  word-break: break-word;
}

.recognition-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.recognition-tag {
  max-width: 100%;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background-color: #eef4ff;
  color: #0a2463;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  word-break: break-word;
}

.recognition-actions {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.recognition-hint {
  font-size: 22rpx;
  color: #6b7a99;
}

.recognition-empty {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: #f7f9fc;
  color: #6b7a99;
  font-size: 25rpx;
  line-height: 1.5;
}

.recognition-retry {
  display: inline-flex;
  margin-top: 18rpx;
}

.subtype-picker {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background-color: #fffaf0;
  border: 1rpx solid #f1dfb8;
}

.subtype-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.subtype-picker-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #8a5a00;
}

.subtype-picker-close {
  font-size: 24rpx;
  color: #6b7a99;
}

.subtype-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.subtype-item {
  min-height: 68rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border: 1rpx solid #f1dfb8;
  color: #1f2d4d;
  font-size: 24rpx;
  line-height: 1.35;
}

.subtype-item.active {
  border-color: #002fa7;
  background-color: #eef4ff;
  color: #002fa7;
  font-weight: 700;
}

.ramp-problem-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.ramp-problem-item {
  min-height: 72rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e6ecf5;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  box-shadow: 0 6rpx 16rpx rgba(10, 36, 99, 0.06);
}

.ramp-problem-item.active {
  border-color: #002fa7;
  background-color: #eef4ff;
  box-shadow: 0 8rpx 20rpx rgba(0, 47, 167, 0.16);
}

.ramp-problem-text {
  font-size: 25rpx;
  color: #0a2463;
  line-height: 1.35;
}

.scheme-match-box {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background-color: #f7f9fc;
  border: 1rpx solid #e6ecf5;
}

.scheme-match-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #e6ecf5;
}

.scheme-match-item:last-child {
  border-bottom: 0;
}

.scheme-code {
  min-width: 92rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #002fa7;
}

.scheme-name {
  flex: 1;
  font-size: 25rpx;
  color: #1f2d4d;
}

.scheme-status {
  font-size: 22rpx;
  color: #6b7a99;
}

.scheme-match-item.ready .scheme-status {
  color: #178a5f;
}

.scheme-match-item.placeholder .scheme-status {
  color: #a36b00;
}

.scheme-empty {
  font-size: 25rpx;
  color: #6b7a99;
}

.contact-input {
  width: 100%;
  background-color: #ffffff;
  border: 2rpx solid #0a2463;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  min-height: 80rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
  box-sizing: border-box;
  line-height: 1.5;
}

.contact-input::placeholder {
  color: #999999;
  font-weight: normal;
}

.contact-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8a96ad;
}

.detail-address-input {
  width: 100%;
  background-color: #ffffff;
  border: 2rpx solid #0a2463;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  min-height: 80rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
  box-sizing: border-box;
  margin-top: 16rpx;
  line-height: 1.5;
}

.detail-address-input::placeholder {
  color: #999999;
  font-weight: normal;
}

.location-text {
  font-size: 26rpx;
  color: #0a2463;
  line-height: 1.6;
}


.reselect-btn {
  background-color: #0a2463;
  color: #ffffff;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
}

.ai-btn {
  background-color: #ffd700;
  color: #0a2463;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
}

.ai-content {
  background-color: #f1f5ff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.ai-text {
  font-size: 26rpx;
  color: #1f2d4d;
}

.ai-textarea {
  width: 100%;
  min-height: 200rpx;
  background-color: #ffffff;
  border: 2rpx solid #002fa7;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.section-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: wrap;
}

.section-title {
  margin-right: 16rpx;
}

.label-hint {
  font-size: 22rpx;
  color: #999;
  margin-right: auto;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-label {
  font-size: 28rpx;
  color: #0a2463;
}

.footer-actions {
  margin: 40rpx 0;
}

.submit-btn {
  background-color: #ffd700;
  color: #0a2463;
  font-weight: 700;
  border-radius: 999rpx;
}

.loading-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #0a2463;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
}
