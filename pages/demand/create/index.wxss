.demand-create-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f8fc;
  box-sizing: border-box;
}

.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 35, 80, 0.06);
}

.form-label {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #172554;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.required {
  color: #ef4444;
}

.label-tip {
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 400;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 2rpx solid #dbe3f0;
  border-radius: 12rpx;
  background: #fbfdff;
  color: #1f2937;
  font-size: 28rpx;
}

.form-input {
  height: 88rpx;
  padding: 0 20rpx;
}

.form-textarea {
  min-height: 180rpx;
  padding: 18rpx 20rpx;
  line-height: 1.55;
}

.input-count {
  margin-top: 10rpx;
  text-align: right;
  color: #9ca3af;
  font-size: 22rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item,
.add-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 34rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.65);
  color: #ffffff;
  font-size: 28rpx;
}

.add-image {
  border: 2rpx dashed #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  background: #f8fafc;
}

.add-icon {
  font-size: 56rpx;
  line-height: 1;
}

.option-row,
.urgency-row {
  display: flex;
  gap: 18rpx;
}

.option-item {
  flex: 1;
  height: 84rpx;
  line-height: 82rpx;
  text-align: center;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  color: #1f2937;
  background: #ffffff;
}

.option-item.active {
  border-color: #1d4ed8;
  color: #1d4ed8;
  background: #eff6ff;
  font-weight: 700;
}

.location-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid #dbe3f0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  background: #fbfdff;
}

.location-name {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.location-address {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.location-action {
  color: #1d4ed8;
  font-size: 26rpx;
  margin-left: 20rpx;
}

.detail-input {
  margin-top: 16rpx;
}

.urgency-item {
  flex: 1;
  min-height: 108rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #ffffff;
}

.urgency-item.active.high {
  border-color: #ef4444;
  background: #fef2f2;
}

.urgency-item.active.medium {
  border-color: #f59e0b;
  background: #fffbeb;
}

.urgency-item.active.low {
  border-color: #22c55e;
  background: #f0fdf4;
}

.urgency-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #172554;
}

.urgency-desc {
  color: #6b7280;
  font-size: 22rpx;
}

.submit-wrap {
  padding: 16rpx 0 40rpx;
}

.submit-btn {
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 12rpx;
  background: #0b46e6;
  color: #ffffff;
  font-weight: 800;
  font-size: 30rpx;
}
